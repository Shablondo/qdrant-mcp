# ==========================================
# Qdrant — локальная векторная база данных
# ==========================================
# Используй host.docker.internal чтобы из контейнера достучаться до
# Qdrant, запущенного на хост-машине (localhost:6333)
QDRANT_URL=http://host.docker.internal:6333
QDRANT_COLLECTION=confluence_docs

# ==========================================
# Embeddings — корпоративная модель
# ==========================================
#
# ВАРИАНТ 1 (рекомендуется) — укажи полный URL до /embeddings endpoint:
# Например: https://api-copilot.x5.ru/aigw/v1/embeddings
EMBED_API_ENDPOINT=https://api-copilot.x5.ru/aigw/v1/embeddings

# ВАРИАНТ 2 — базовый URL (openai SDK добавит /embeddings сам):
# Например: https://api-copilot.x5.ru/aigw/v1
# EMBED_API_BASE=https://api-copilot.x5.ru/aigw/v1

# API ключ для авторизации
COPILOT_API_KEY=your_api_key_here

# Название модели
EMBED_MODEL=copilot-embed-4b

# Размерность векторов модели
EMBED_DIMENSIONS=2560

# ==========================================
# Confluence
# ==========================================
CONFLUENCE_URL=https://wiki.x5.ru
CONFLUENCE_PERSONAL_TOKEN=your_confluence_personal_token_here
# Отключить проверку SSL сертификата (false = отключить)
CONFLUENCE_SSL_VERIFY=false

# ==========================================
# Параметры чанкинга (опционально)
# ==========================================
# Максимальный размер чанка в токенах
CHUNK_MAX_TOKENS=500
# Overlap между чанками в токенах
CHUNK_OVERLAP_TOKENS=50

# ==========================================
# Allure TestOps
# ==========================================
ALLURE_TESTOPS_URL=https://your-allure-testops.com
ALLURE_TESTOPS_API_TOKEN=your_allure_testops_api_token_here
ALLURE_TESTOPS_PROJECT_ID=123

